DEFAULT_PROVIDER=groq
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=

QDRANT_URL=http://your-qdrant-private-host:6333
