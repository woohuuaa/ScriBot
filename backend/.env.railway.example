# Railway / hosted profile
# - Embeddings use FastEmbed instead of Ollama
# - Qdrant is reached via a private service URL
# - Groq is the recommended default response provider

DEFAULT_PROVIDER=groq
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
ENABLE_CACHE=true
ENABLE_RAG_CACHE=true
ENABLE_RESPONSE_CACHE=true
RAG_CACHE_TTL_SECONDS=600
RESPONSE_CACHE_TTL_SECONDS=900
RAG_CACHE_MAX_ENTRIES=100
CHAT_RESPONSE_CACHE_MAX_ENTRIES=100
AGENT_RESPONSE_CACHE_MAX_ENTRIES=50

# Required if you want to use hosted admin endpoints such as
# /api/admin/index-docs, /api/admin/cache/stats, and /api/admin/cache/clear
ADMIN_TOKEN=6b93eba7817eb0899363b0ca656d5f735b02e2c99696fbeda8b4c1750e7969c2

GROQ_API_KEY=
OPENAI_API_KEY=

QDRANT_URL=http://your-qdrant-private-host:6333
QDRANT_COLLECTION=kdai_docs

# Optional provider metadata only. Do not set OLLAMA_BASE_URL on Railway
# unless you are explicitly hosting a reachable Ollama instance.
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
